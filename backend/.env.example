# ============================================================
#  Wasify AI - Backend Environment Variables
#  Copy this file to .env and fill in your values
# ============================================================

# ---  Security  ---
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars

# JWT token expiry
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---  Database  ---
# Option A: SQLite (local development - works out of the box, no install needed)
DATABASE_URL=sqlite:///./wasify.db

# Option B: Supabase PostgreSQL (for production)
# Get this from your Supabase project: Settings > Database > Connection string (URI mode)
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ---  File Storage  ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ---  CORS  ---
# Add your mobile app's IP or deployed frontend URL
ALLOWED_ORIGINS=http://localhost:3000,http://10.0.2.2:8000
